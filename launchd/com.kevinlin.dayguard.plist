<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kevinlin.dayguard</string>

  <!-- IMPORTANT: Edit these two paths to match your install location -->
  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>

  <!-- Invoke python directly with `-m uvicorn` so we don't depend on the
       venv's uvicorn wrapper script (whose shebang can fail under launchd's
       restricted env).
       The venv lives in ~/Library (NOT ~/Documents) because iCloud Drive
       evicts file contents from Documents, which makes launchd-spawned
       Python die with "Resource deadlock avoided" on import.
       __PROJECT_DIR__ / __VENV_DIR__ are placeholders substituted by
       `dayguardctl install` with this machine's real paths — don't hardcode
       a path here, edit dayguardctl's $DIR / $VENV instead. -->
  <key>ProgramArguments</key>
  <array>
    <string>__VENV_DIR__/bin/python3</string>
    <string>-m</string>
    <string>uvicorn</string>
    <string>app.main:app</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8765</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__VENV_DIR__/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <!-- Make sure tracebacks are flushed to the log before the process dies -->
    <key>PYTHONUNBUFFERED</key>
    <string>1</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <!-- Only restart on crash, not on clean exit. Prevents tight respawn loops
       if the server fails fast on a bad config. -->
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <!-- Wait 10s between restart attempts so a fast-failing process
       (e.g. port already in use) doesn't spin -->
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <!-- Logs live inside the project so they survive reboots and are easy to find -->
  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/logs/dayguard.out.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/logs/dayguard.err.log</string>
</dict>
</plist>
